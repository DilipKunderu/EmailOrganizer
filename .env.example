# === Deployment ===
DEPLOY_MODE=local                    # local | cloud

# === Gmail OAuth ===
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret

# === Cloud only ===
# DATABASE_URL=postgresql://user:pass@localhost:5432/emailorganizer
# MULTI_TENANT=false

# === LLM Providers (optional, enable one) ===
# Local (default): configure llm.provider=llamacpp in config/settings.yaml.
# Works with LM Studio (port 1234), llama.cpp --server (8080), vLLM, etc.
# No API key needed.
#
# Cloud (optional):
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
